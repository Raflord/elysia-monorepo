{
  "name": "elysia-monorepo",
  "version": "0.0.1",
  "description": "A monorepo template built with Bun, Elysia, Kysely, React and Better Auth",
  "author": "Rafael Wrobel",
  "license": "MIT",
  "homepage": "https://github.com/raflord/elysia-monorepo",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "./client",
    "./server",
    "./shared"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:client": "turbo dev --filter=@client",
    "dev:server": "turbo dev --filter=@server",
    "build": "turbo build",
    "build:client": "turbo build --filter=@client",
    "build:server": "turbo build --filter=@server",
    "lint": "biome lint .",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "turbo build --filter=@shared --filter=@server --filter=@client",
    "format": "biome format . --write"
  },
  "keywords": [
    "bun",
    "elysia",
    "react",
    "vite",
    "monorepo",
    "turbo",
    "kysely",
    "better-auth"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "bun-types": "latest",
    "turbo": "^2.8.21"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "elysia": "^1.4.25"
  }
}
